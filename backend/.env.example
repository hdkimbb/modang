# Database (SQLite for local dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./modang.db

# Kakao Local API (https://developers.kakao.com)
KAKAO_REST_API_KEY=your_rest_api_key_here
# DATABASE_URL=postgresql://user:password@localhost:5432/modang

# Comma-separated origins for CORS (Next.js default port)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

ENVIRONMENT=development
